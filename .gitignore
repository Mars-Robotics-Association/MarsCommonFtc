# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java/JDK files
*.class
*.hprof

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/

# For Mac users
.DS_Store

# Claude Code local state
.claude/

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Vendored third-party trees checked out locally for experiments (not part of the product).
# Anchored to the repo root: an unanchored ruckig/ also swallows Java package
# directories like RuckigJava/src/main/java/com/ruckig/.
/ruckig/

# ControlLab flight-recorder session logs (per-tick CSVs written by the GUI)
controllab-logs/
